    "addition": [
        "<div style='background-color: #1A1A1E; border: 2px solid #7B2CBF; border-radius: 8px; padding: 12px; margin: 5px 0;'>\n<span style='color: #A5D6A7; font-weight: bold; font-size: 13px;'>➕ OPERATION: ADDITION</span><br>\n<hr style='border: 0; border-top: 1px solid #7B2CBF; margin: 8px 0;'>\n<p style='margin: 4px 0; color: #E2E2E6;'>Die Addition ist eine der vier Grundrechenarten. Sie beschreibt das Zusammenzählen von mindestens zwei Größen (Summanden).</p>\n<table width='100%' style='margin-top: 10px; font-family: monospace; border-collapse: collapse;'>\n  <tr style='background-color: #252529;'>\n    <th style='padding: 6px; color: #9D4EDD; text-align: left;'>Begriff</th>\n    <th style='padding: 6px; color: #9D4EDD; text-align: left;'>Formel-Komponente</th>\n  </tr>\n  <tr>\n    <td style='padding: 6px; border-bottom: 1px solid #2C2C35; color: #8E9AAF;'>1. Summand</td>\n    <td style='padding: 6px; border-bottom: 1px solid #2C2C35; color: #FF79C6;'>$a$</td>\n  </tr>\n  <tr>\n    <td style='padding: 6px; border-bottom: 1px solid #2C2C35; color: #8E9AAF;'>2. Summand</td>\n    <td style='padding: 6px; border-bottom: 1px solid #2C2C35; color: #FF79C6;'>$b$</td>\n  </tr>\n  <tr style='background-color: #1C2333;'>\n    <td style='padding: 6px; color: #A5D6A7; font-weight: bold;'>Summe (Ergebnis)</td>\n    <td style='padding: 6px; color: #A5D6A7; font-weight: bold;'>$s = a + b$</td>\n  </tr>\n</table>\n</div>"
